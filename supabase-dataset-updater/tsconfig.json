{
    "compilerOptions": {
        "lib": ["es2023", "DOM"],
        "module": "NodeNext",
        "target": "es2022",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "NodeNext",
        "resolveJsonModule": true
    },
    "include": ["src/**/*"]
}


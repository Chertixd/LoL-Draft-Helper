{
    "name": "counterpick-app",
    "version": "1.0.1",
    "description": "LoL Champion Counter & Draft Analyzer - Desktop App",
    "private": true,
    "scripts": {
        "dev": "pnpm run --filter @counterpick/frontend dev",
        "dev:frontend": "pnpm run --filter @counterpick/frontend dev",
        "build": "turbo build",
        "typecheck": "turbo typecheck",
        "lint": "turbo lint",
        "backend": "cd apps/backend && python backend.py",
        "backend:setup": "cd apps/backend && pip install -r requirements.txt && pip install -e .",
        "tauri": "tauri"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2",
        "@types/node": "^20.10.0",
        "tsx": "^4.6.1",
        "turbo": "^2.5.3",
        "typescript": "^5.3.2"
    },
    "packageManager": "pnpm@9.2.0",
    "engines": {
        "node": ">=18.0.0"
    }
}


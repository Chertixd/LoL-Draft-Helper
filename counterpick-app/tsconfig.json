{
    "compilerOptions": {
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "target": "ES2022",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "preserve"
    },
    "exclude": ["node_modules", "dist"]
}

